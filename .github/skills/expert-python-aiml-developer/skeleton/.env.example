# Application settings
APP_NAME=ml-project
APP_ENV=development
LOG_LEVEL=INFO

# Model settings
MODEL_NAME=efficientnet_b0
MODEL_PATH=models/production/model.pt
MODEL_NUM_CLASSES=10
MODEL_IMAGE_SIZE=224

# Training settings
TRAIN_SEED=42
TRAIN_EPOCHS=100
TRAIN_BATCH_SIZE=32
TRAIN_LEARNING_RATE=0.0001
TRAIN_DEVICE=cuda

# Inference settings
INFERENCE_BATCH_SIZE=64
INFERENCE_DEVICE=cuda
INFERENCE_CONFIDENCE_THRESHOLD=0.5

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# External services (uncomment as needed)
# OPENAI_API_KEY=sk-...
# MLFLOW_TRACKING_URI=http://localhost:5000
# WANDB_API_KEY=...
